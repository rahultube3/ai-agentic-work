# Copy to .env. Leave SKILLS_REPO empty for local mode (reads ./skills/).

# --- Local mode (default) ---
# SKILLS_DIR=/abs/path/to/skills

# --- GitHub mode (set SKILLS_REPO to enable) ---
# SKILLS_REPO=rahultube3/ai-agentic-work
# SKILLS_BRANCH=main
# SKILLS_REPO_PATH=skills

# Optional. Required for private repos; raises public-repo rate limit from 60 to 5000/hr.
# GITHUB_TOKEN=ghp_xxx

# --- Jira Story Writer Agent ---
ANTHROPIC_API_KEY=sk-ant-xxx
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ
# Story points field ID — check your Jira project type:
#   classic projects  → customfield_10016
#   next-gen projects → customfield_10028
JIRA_STORY_POINTS_FIELD=story_points
